# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── Upstream APIs ────────────────────────────────────
SBO_API_URL=http://localhost:4001
AGGREGATOR_API_URL=http://localhost:4002

# ─── Bet Splitting ────────────────────────────────────
MIN_STAKE=100

# ─── Retry Strategy ──────────────────────────────────
AGGREGATOR_MAX_RETRIES=2
AGGREGATOR_RETRY_DELAY_MS=500

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Outbound Proxy (optional) ───────────────────────
# OUTBOUND_PROXY_HOST=209.50.185.190
# OUTBOUND_PROXY_PORT=3129
# OUTBOUND_PROXY_USER=uyqfukkl9k47
# OUTBOUND_PROXY_PASS=p3t6eijg0rh3ntp

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
